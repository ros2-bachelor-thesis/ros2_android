@@ -0,0 +1,544 @@
+#if defined(__ANDROID__)
+
+#include "android_jni_serial.h"
+
+#include <unistd.h>
+#include <cstring>
+#include <android/log.h>
+
+#define LOG_TAG "YDLidarSDK_Serial"
+
+#define LOGI(...) __android_log_print(ANDROID_LOG_INFO, LOG_TAG, __VA_ARGS__)
+#define LOGW(...) __android_log_print(ANDROID_LOG_WARN, LOG_TAG, __VA_ARGS__)
+#define LOGE(...) __android_log_print(ANDROID_LOG_ERROR, LOG_TAG, __VA_ARGS__)
+
+namespace ydlidar {
+namespace core {
+namespace serial {
+
+// Global JNI references (cached at initialization)
+extern JavaVM* g_javaVM;  // Declared in jni_bridge.cc
+extern jclass g_usbSerialBridgeClass;
+extern jclass g_bufferedSerialClass;
+extern jmethodID g_openDeviceMethod;
+extern jmethodID g_closeDeviceMethod;
+extern jmethodID g_availableMethod;
+extern jmethodID g_readMethod;
+extern jmethodID g_writeMethod;
+extern jmethodID g_flushMethod;
+
+using serial::Serial;
+
+Serial::SerialImpl::SerialImpl(
+    const std::string &port,
+    unsigned long baudrate,
+    bytesize_t bytesize,
+    parity_t parity,
+    stopbits_t stopbits,
+    flowcontrol_t flowcontrol)
+  : port_(port),
+    is_open_(false),
+    java_port_ref_(nullptr),
+    baudrate_(baudrate),
+    byte_time_ns_(0),
+    parity_(parity),
+    bytesize_(bytesize),
+    stopbits_(stopbits),
+    flowcontrol_(flowcontrol),
+    last_error_(Serial::NoError) {
+
+  // Note: No mutexes needed - CircularByteBuffer in Java is already thread-safe
+
+  // Calculate byte time for timing operations
+  uint32_t bit_time_ns = 1e9 / baudrate_;
+  byte_time_ns_ = bit_time_ns * (1 + bytesize_ + (parity_ != parity_none ? 1 : 0) + stopbits_);
+
+  LOGI("SerialImpl created: port=%s, baud=%lu", port_.c_str(), baudrate_);
+}
+
+Serial::SerialImpl::~SerialImpl() {
+  close();
+  // Note: No mutexes to destroy - Java layer handles thread safety
+}
+
+JNIEnv* Serial::SerialImpl::getJNIEnv() {
+  JNIEnv* env = nullptr;
+
+  if (g_javaVM == nullptr) {
+    LOGE("g_javaVM is null - JNI not initialized");
+    return nullptr;
+  }
+
+  int status = g_javaVM->GetEnv((void**)&env, JNI_VERSION_1_6);
+
+  if (status == JNI_EDETACHED) {
+    // Thread not attached, attach it
+    status = g_javaVM->AttachCurrentThread(&env, nullptr);
+    if (status != JNI_OK) {
+      LOGE("Failed to attach thread to JVM: %d", status);
+      return nullptr;
+    }
+  } else if (status != JNI_OK) {
+    LOGE("Failed to get JNI environment: %d", status);
+    return nullptr;
+  }
+
+  return env;
+}
+
+void Serial::SerialImpl::detachJNIEnv() {
+  // Note: We don't detach here because the thread may be reused
+  // The JVM will automatically detach when the thread exits
+}
+
+bool Serial::SerialImpl::open() {
+  if (is_open_) {
+    LOGW("Port already open: %s", port_.c_str());
+    return true;
+  }
+
+  LOGI("Opening port: %s (baud=%lu, data=%d, stop=%d, parity=%d)",
+       port_.c_str(), baudrate_, bytesize_, stopbits_, parity_);
+
+  JNIEnv* env = getJNIEnv();
+  if (env == nullptr) {
+    LOGE("Failed to get JNI environment");
+    last_error_ = Serial::OpenError;
+    return false;
+  }
+
+  // Check if JNI globals are initialized
+  if (g_usbSerialBridgeClass == nullptr || g_openDeviceMethod == nullptr) {
+    LOGE("JNI not initialized - UsbSerialBridge.nativeInitJNI() not called yet");
+    last_error_ = Serial::OpenError;
+    return false;
+  }
+
+  // Convert parameters to Java format
+  jstring jDeviceId = env->NewStringUTF(port_.c_str());
+  if (jDeviceId == nullptr) {
+    LOGE("Failed to create Java string for device ID");
+    last_error_ = Serial::OpenError;
+    return false;
+  }
+
+  // Map SDK parameters to USB Serial library format
+  int dataBits = static_cast<int>(bytesize_);
+
+  // stopbits: 0=1 bit, 1=1.5 bits, 2=2 bits (USB Serial format)
+  int stopBits = (stopbits_ == stopbits_one) ? 0 :
+                 (stopbits_ == stopbits_two) ? 2 : 1;
+
+  // parity: 0=none, 1=odd, 2=even (mark/space not supported by USB Serial)
+  int parity = (parity_ == parity_none) ? 0 :
+               (parity_ == parity_odd) ? 1 :
+               (parity_ == parity_even) ? 2 : 0;
+
+  // Call UsbSerialBridge.openDevice(deviceId, baudrate, dataBits, stopBits, parity)
+  jobject portObj = env->CallStaticObjectMethod(
+      g_usbSerialBridgeClass,
+      g_openDeviceMethod,
+      jDeviceId,
+      static_cast<jint>(baudrate_),
+      dataBits,
+      stopBits,
+      parity
+  );
+
+  env->DeleteLocalRef(jDeviceId);
+
+  if (portObj == nullptr || env->ExceptionCheck()) {
+    if (env->ExceptionCheck()) {
+      env->ExceptionDescribe();
+      env->ExceptionClear();
+    }
+    LOGE("Failed to open device: %s", port_.c_str());
+    last_error_ = Serial::OpenError;
+    return false;
+  }
+
+  // Convert to global reference (local refs are only valid in this scope)
+  java_port_ref_ = env->NewGlobalRef(portObj);
+  env->DeleteLocalRef(portObj);
+
+  if (java_port_ref_ == nullptr) {
+    LOGE("Failed to create global reference for port object");
+    last_error_ = Serial::OpenError;
+    return false;
+  }
+
+  is_open_ = true;
+  last_error_ = Serial::NoError;
+
+  LOGI("Port opened successfully: %s", port_.c_str());
+  return true;
+}
+
+void Serial::SerialImpl::close() {
+  if (!is_open_) {
+    return;
+  }
+
+  LOGI("Closing port: %s", port_.c_str());
+
+  JNIEnv* env = getJNIEnv();
+  if (env != nullptr && java_port_ref_ != nullptr) {
+    // Call UsbSerialBridge.closeDevice(deviceId) if JNI is initialized
+    if (g_usbSerialBridgeClass != nullptr && g_closeDeviceMethod != nullptr) {
+      jstring jDeviceId = env->NewStringUTF(port_.c_str());
+      if (jDeviceId != nullptr) {
+        env->CallStaticVoidMethod(
+            g_usbSerialBridgeClass,
+            g_closeDeviceMethod,
+            jDeviceId
+        );
+        env->DeleteLocalRef(jDeviceId);
+      }
+    }
+
+    // Release global reference
+    env->DeleteGlobalRef(java_port_ref_);
+    java_port_ref_ = nullptr;
+  }
+
+  is_open_ = false;
+  LOGI("Port closed: %s", port_.c_str());
+}
+
+bool Serial::SerialImpl::isOpen() const {
+  return is_open_;
+}
+
+size_t Serial::SerialImpl::available() {
+  if (!is_open_) {
+    return 0;
+  }
+
+  JNIEnv* env = getJNIEnv();
+  if (env == nullptr || g_availableMethod == nullptr || java_port_ref_ == nullptr) {
+    return 0;
+  }
+
+  // Call bufferedPort.available()
+  jint count = env->CallIntMethod(java_port_ref_, g_availableMethod);
+
+  if (env->ExceptionCheck()) {
+    env->ExceptionDescribe();
+    env->ExceptionClear();
+    return 0;
+  }
+
+  return static_cast<size_t>(count);
+}
+
+size_t Serial::SerialImpl::read(uint8_t *buf, size_t size) {
+  if (!is_open_ || buf == nullptr || size == 0) {
+    return 0;
+  }
+
+  JNIEnv* env = getJNIEnv();
+  if (env == nullptr || g_readMethod == nullptr || java_port_ref_ == nullptr) {
+    return 0;
+  }
+
+  // Create Java byte array
+  jbyteArray jBuf = env->NewByteArray(static_cast<jsize>(size));
+  if (jBuf == nullptr) {
+    LOGE("Failed to allocate Java byte array for read");
+    return 0;
+  }
+
+  // Calculate timeout in milliseconds
+  uint32_t timeout_ms = timeout_.read_timeout_constant +
+                        (timeout_.read_timeout_multiplier * static_cast<uint32_t>(size));
+
+  // Call bufferedPort.read(byteArray, timeout)
+  jint bytesRead = env->CallIntMethod(
+      java_port_ref_,
+      g_readMethod,
+      jBuf,
+      static_cast<jint>(timeout_ms)
+  );
+
+  if (env->ExceptionCheck()) {
+    env->ExceptionDescribe();
+    env->ExceptionClear();
+    env->DeleteLocalRef(jBuf);
+    return 0;
+  }
+
+  if (bytesRead > 0) {
+    // Copy Java bytes to C++ buffer
+    env->GetByteArrayRegion(jBuf, 0, bytesRead, reinterpret_cast<jbyte*>(buf));
+  }
+
+  env->DeleteLocalRef(jBuf);
+
+  return static_cast<size_t>(bytesRead > 0 ? bytesRead : 0);
+}
+
+size_t Serial::SerialImpl::write(const uint8_t *data, size_t length) {
+  if (!is_open_ || data == nullptr || length == 0) {
+    return 0;
+  }
+
+  JNIEnv* env = getJNIEnv();
+  if (env == nullptr || g_writeMethod == nullptr || java_port_ref_ == nullptr) {
+    return 0;
+  }
+
+  // Create Java byte array and copy data
+  jbyteArray jData = env->NewByteArray(static_cast<jsize>(length));
+  if (jData == nullptr) {
+    LOGE("Failed to allocate Java byte array for write");
+    return 0;
+  }
+
+  env->SetByteArrayRegion(jData, 0, static_cast<jsize>(length),
+                          reinterpret_cast<const jbyte*>(data));
+
+  // Calculate timeout
+  uint32_t timeout_ms = timeout_.write_timeout_constant +
+                        (timeout_.write_timeout_multiplier * static_cast<uint32_t>(length));
+
+  // Call bufferedPort.write(byteArray, timeout)
+  env->CallVoidMethod(
+      java_port_ref_,
+      g_writeMethod,
+      jData,
+      static_cast<jint>(timeout_ms)
+  );
+
+  bool success = !env->ExceptionCheck();
+
+  if (!success) {
+    env->ExceptionDescribe();
+    env->ExceptionClear();
+  }
+
+  env->DeleteLocalRef(jData);
+
+  return success ? length : 0;
+}
+
+int Serial::SerialImpl::waitfordata(size_t data_count, uint32_t timeout, size_t *returned_size) {
+  if (!is_open_) {
+    return -2;  // Error: port not open
+  }
+
+  uint64_t start_time = 0;
+  uint64_t elapsed = 0;
+
+  // Get start time (milliseconds)
+  struct timespec ts;
+  clock_gettime(CLOCK_MONOTONIC, &ts);
+  start_time = ts.tv_sec * 1000 + ts.tv_nsec / 1000000;
+
+  while (is_open_) {
+    size_t avail = available();
+
+    if (avail >= data_count) {
+      if (returned_size) {
+        *returned_size = avail;
+      }
+      return 0;  // Success: enough data available
+    }
+
+    // Check timeout
+    clock_gettime(CLOCK_MONOTONIC, &ts);
+    uint64_t current_time = ts.tv_sec * 1000 + ts.tv_nsec / 1000000;
+    elapsed = current_time - start_time;
+
+    if (elapsed >= timeout) {
+      if (returned_size) {
+        *returned_size = avail;
+      }
+      return -1;  // Timeout
+    }
+
+    // Sleep briefly to avoid busy-waiting (10ms)
+    usleep(10000);
+  }
+
+  return -2;  // Error: port closed during wait
+}
+
+bool Serial::SerialImpl::waitReadable(uint32_t timeout) {
+  size_t dummy;
+  return waitfordata(1, timeout, &dummy) == 0;
+}
+
+void Serial::SerialImpl::waitByteTimes(size_t count) {
+  // Calculate sleep time based on byte transmission time
+  uint32_t sleep_ns = byte_time_ns_ * count;
+
+  struct timespec ts;
+  ts.tv_sec = sleep_ns / 1000000000;
+  ts.tv_nsec = sleep_ns % 1000000000;
+
+  nanosleep(&ts, nullptr);
+}
+
+void Serial::SerialImpl::flush() {
+  flushInput();
+  flushOutput();
+}
+
+void Serial::SerialImpl::flushInput() {
+  if (!is_open_) {
+    return;
+  }
+
+  JNIEnv* env = getJNIEnv();
+  if (env == nullptr || g_flushMethod == nullptr || java_port_ref_ == nullptr) {
+    return;
+  }
+
+  // Call bufferedPort.flush(true, false)
+  env->CallVoidMethod(java_port_ref_, g_flushMethod, JNI_TRUE, JNI_FALSE);
+
+  if (env->ExceptionCheck()) {
+    env->ExceptionClear();
+  }
+}
+
+void Serial::SerialImpl::flushOutput() {
+  if (!is_open_) {
+    return;
+  }
+
+  JNIEnv* env = getJNIEnv();
+  if (env == nullptr || g_flushMethod == nullptr || java_port_ref_ == nullptr) {
+    return;
+  }
+
+  // Call bufferedPort.flush(false, true)
+  env->CallVoidMethod(java_port_ref_, g_flushMethod, JNI_FALSE, JNI_TRUE);
+
+  if (env->ExceptionCheck()) {
+    env->ExceptionClear();
+  }
+}
+
+bool Serial::SerialImpl::setBaudrate(unsigned long baudrate) {
+  baudrate_ = baudrate;
+
+  // Recalculate byte time
+  uint32_t bit_time_ns = 1e9 / baudrate_;
+  byte_time_ns_ = bit_time_ns * (1 + bytesize_ + (parity_ != parity_none ? 1 : 0) + stopbits_);
+
+  // Note: Baud rate change requires reopen on Android
+  // The SDK typically sets this before calling open()
+  return true;
+}
+
+bool Serial::SerialImpl::setStandardBaudRate(unsigned long baudrate) {
+  return setBaudrate(baudrate);
+}
